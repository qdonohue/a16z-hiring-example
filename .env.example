# LLM Provider (one of these is required):
# Option 1: Vercel AI Gateway (recommended — handles tool schemas correctly)
# AI_GATEWAY_API_KEY=
# Option 2: Direct Anthropic API key (tools in /setup won't work due to SDK bug)
# ANTHROPIC_API_KEY=

# Required: Composio API key for integrations
# Get from: https://app.composio.dev
# Without this, mock data is used for all enrichment + post-interview actions
COMPOSIO_API_KEY=

# Optional: Composio entity ID (defaults to "a16z-interview-agent")
# All connections are scoped to this entity. Connect at /setup.
# COMPOSIO_ENTITY_ID=a16z-interview-agent

# Optional: Google Drive folder ID for interview reports
# GOOGLE_DRIVE_REPORTS_FOLDER_ID=

# Optional: Google Sheets spreadsheet ID for pipeline tracker
# GOOGLE_SHEETS_TRACKER_ID=

# Optional: Slack channel for hiring notifications
# SLACK_HIRING_CHANNEL=#hiring-growth-fellowship
